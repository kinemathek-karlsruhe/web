# Copy this file to .env and fill in. .env is gitignored; this template is committed.
#
# TMDB credentials for the Panel film lookup (server-side, cached — the public
# site never calls TMDB). Use EITHER a v3 API key (32-hex) OR a v4 bearer token
# (a long JWT) — not both. Get one at https://www.themoviedb.org/settings/api
TMDB_KEY=
TMDB_TOKEN=
